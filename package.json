{
  "name": "lightning-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @lightning/desktop dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "bindings": "node scripts/gen-bindings.mjs",
    "e2e": "pnpm --filter @lightning/e2e wdio",
    "check:targets": "node scripts/check-targets.mjs",
    "licenses:check": "node scripts/check-licenses.mjs",
    "verify": "node scripts/verify.mjs",
    "version:sync": "node scripts/sync-version.mjs"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.4"
  }
}
