  The wizard window: Mica backdrop, animated progress (§6.10). All strings
  come from .resw resources (x:Uid) — never literals in XAML (§2.9). The
  progress animation respects the Windows reduced-motion setting (§9.2).
-->
<Window
    x:Class="Lightning.Installer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop xmlns="using:Microsoft.UI.Xaml.Media" />
    </Window.SystemBackdrop>

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock x:Uid="WelcomeTitle" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                x:Uid="WelcomeSubtitle"
                Style="{StaticResource BodyTextBlockStyle}"
                Opacity="0.7" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="12" VerticalAlignment="Center">
            <CheckBox x:Uid="OptionAutostart" IsChecked="{x:Bind ViewModel.Autostart, Mode=TwoWay}" />
            <CheckBox x:Uid="OptionAddToPath" IsChecked="{x:Bind ViewModel.AddToPath, Mode=TwoWay}" />
            <CheckBox x:Uid="OptionFileAssociation" IsChecked="{x:Bind ViewModel.FileAssociation, Mode=TwoWay}" />
            <CheckBox x:Uid="OptionProtocol" IsChecked="{x:Bind ViewModel.ProtocolHandler, Mode=TwoWay}" />
            <CheckBox x:Uid="OptionStartMenu" IsChecked="{x:Bind ViewModel.StartMenuShortcut, Mode=TwoWay}" />
            <CheckBox x:Uid="OptionDesktop" IsChecked="{x:Bind ViewModel.DesktopShortcut, Mode=TwoWay}" />
            <ProgressBar
                Minimum="0"
                Maximum="1"
                Value="{x:Bind ViewModel.Progress, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsInstalling, Mode=OneWay}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Uid="CancelButton" Command="{x:Bind ViewModel.CancelCommand}" />
            <Button
                x:Uid="InstallButton"
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.InstallCommand}" />
        </StackPanel>
    </Grid>
</Window>
