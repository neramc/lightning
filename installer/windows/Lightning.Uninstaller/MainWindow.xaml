<Window
    x:Class="Lightning.Uninstaller.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop xmlns="using:Microsoft.UI.Xaml.Media" />
    </Window.SystemBackdrop>

    <StackPanel Padding="32" Spacing="16" VerticalAlignment="Center">
        <TextBlock x:Uid="UninstallTitle" Style="{StaticResource TitleTextBlockStyle}" />
        <CheckBox x:Uid="KeepDataOption" IsChecked="{x:Bind ViewModel.KeepUserData, Mode=TwoWay}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Uid="CancelButton" Command="{x:Bind ViewModel.CancelCommand}" />
            <Button
                x:Uid="UninstallButton"
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.UninstallCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
